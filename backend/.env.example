# Database (PostgreSQL)
# For local dev, use localhost if PostgreSQL is installed locally and create DB: createdb cachewebsite
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/cachewebsite

# Optional: remote DB (e.g. when on VPN). If connection times out, use localhost above.
# DATABASE_URL=postgresql://postgres:1234@172.16.110.46:5432/cachewebsite

OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=cachebot
PINECONE_REGION=us-east-1
