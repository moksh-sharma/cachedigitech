# Server port (default 3000)
PORT=3000

# PostgreSQL (required for admin panel: blogs + latest highlights)
# Network example: postgresql://user:password@host:5432/dbname
# Localhost example: postgresql://cachedigitech:yourpassword@localhost:5432/cachedigitech
DATABASE_URL=postgresql://user:password@host:5432/dbname

# For db:restore-local — target DB URL when restoring (optional; falls back to DATABASE_URL)
# Use the same format as DATABASE_URL (e.g. your new pgAdmin server).
# LOCAL_DATABASE_URL=postgresql://user:password@host:5432/dbname

# Chat (hero section chatbot)
OPENAI_API_KEY=

# Blog CMS (email + password for /admin)
BLOG_ADMIN_EMAIL=admin@cachedigitech.com
BLOG_ADMIN_PASSWORD=admin
SESSION_SECRET=change-me-in-production

# Optional: override defaults (no database)
# CHATBOT_ENABLED=true
# CHATBOT_SYSTEM_PROMPT=   (leave empty for default Cache Digitech assistant)
# CHATBOT_MODEL=gpt-4o-mini
# CHATBOT_MAX_TOKENS=512
# CHATBOT_EXPAND_SPEED=1.2
# CHATBOT_TEXT_FADE_SPEED=0.8
